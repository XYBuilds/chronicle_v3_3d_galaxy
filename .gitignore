# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg
.venv/
venv/
/env/
*.pyo
*.pdb

# ============================================================
# Raw / large data  (subsample/ is tracked)
# ============================================================
# Match directory or M6 WSL symlink at data/raw (trailing-slash-only rules miss symlinks).
data/raw
data/output/
scripts/output/
*.pkl
*.joblib

# ============================================================
# Frontend (Node / Vite / Storybook)
# ============================================================
node_modules/
frontend/dist/
frontend/storybook-static/
frontend/.vite/
frontend/.cache/
# P7.2: only galaxy_data.json.gz is tracked; pipeline writes .json locally (ignored).
frontend/public/data/*.json
frontend/public/data/*.json.gz
!frontend/public/data/galaxy_data.json.gz

# ============================================================
# IDE / OS
# ============================================================
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.code-workspace

# ============================================================
# Docs (local / machine-specific)
# ============================================================
docs/project_docs/视觉参数总表.md

# ============================================================
# Misc
# ============================================================
*.log
.env
.env.*
